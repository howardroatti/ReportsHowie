# ============================================================
# ReportsHowie - .gitignore para projetos Delphi / RAD Studio
# ============================================================

# Saidas de compilacao
*.dcu
*.o
*.obj
*.a
*.lib
*.bpl
*.bpi
*.dcp
*.so
*.apk
*.drc
*.map
*.dres
*.rsm
*.tds
*.dcu
*.exe
*.dll
*.map

# Diretorios de build
dcu/
Win32/
Win64/
Android/
Android64/
iOSDevice64/
iOSSimulator/
OSX64/
Linux64/
__history/
__recovery/
bin/
lib/

# Arquivos locais e de usuario do IDE (nao versionar)
*.local
*.identcache
*.projdata
*.tvsconfig
*.dsk
*.stat
*.groupproj.local
*.otares
modules/

# Arquivos temporarios
*.~*
*.bak
*.tmp

# Nao ignoramos os .dproj / .dpk / .groupproj: eles descrevem o projeto
# e devem ser versionados.
