# ============================================================
# ReportsHowie - .gitignore para projetos Delphi / RAD Studio
# ============================================================

# Saidas de compilacao
*.dcu
*.res
*.otares
*.o
*.obj
*.a
*.lib
*.bpl
*.bpi
*.dcp
*.so
*.apk
*.drc
*.map
*.dres
*.rsm
*.tds
*.dcu
*.exe
*.dll
*.map

# Diretorios de build
dcu/
Win32/
Win64/
Android/
Android64/
iOSDevice64/
iOSSimulator/
OSX64/
Linux64/
__history/
__recovery/
bin/
lib/

# Arquivos locais e de usuario do IDE (nao versionar)
*.local
*.identcache
*.projdata
*.tvsconfig
*.dsk
*.stat
*.groupproj.local
*.otares
modules/

# Arquivos temporarios
*.~*
*.bak
*.tmp

# Nao ignoramos os .dproj / .dpk / .groupproj: eles descrevem o projeto
# e devem ser versionados.

# Instrucoes locais do Claude Code (contem conta/paths especificos da maquina)
CLAUDE.md

# Saidas binarias geradas dos demos (regeneraveis via rhtool) — os .rhr,
# .data.json e as saidas de referencia .pdf/.html permanecem versionados.
demos/vendas.docx
demos/vendas.xlsx

# Artefatos de empacotamento do release (pack-release.ps1)
dist/

# Python (servidor MCP / scripts utilitarios)
__pycache__/
*.pyc
.venv/
venv/

# Saidas geradas pelas ferramentas de linha de comando (rhtool / mcp)
tools/rhtool/*.pdf
tools/rhtool/*.html
tools/rhtool/*.xlsx
tools/rhtool/*.docx
tools/mcp/*.pdf
tools/mcp/inbox/
